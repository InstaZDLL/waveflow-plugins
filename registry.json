{
  "$schema": "./schema/registry.schema.json",
  "schema_version": 1,
  "plugins": [
    {
      "id": "apple-artwork",
      "name": "Apple Motion Artwork",
      "description": "Animated album covers from Apple Music, rendered behind the now-playing view.",
      "author": "InstaZDLL",
      "repo": "InstaZDLL/waveflow-plugin-apple-artwork",
      "homepage": "https://github.com/InstaZDLL/waveflow-plugin-apple-artwork",
      "world": "waveflow:metadata/v1",
      "version": "0.1.0",
      "blake3": "05f929b96e6672b76d5fed1fa0730b5b86d4a78f51d3894b43fe78532569fca6",
      "permissions": {
        "http": [
          "https://itunes.apple.com/**",
          "https://music.apple.com/**",
          "https://amp-api.music.apple.com/**",
          "https://mvod.itunes.apple.com/**"
        ],
        "storage_read": false,
        "storage_state": true
      },
      "tags": ["artwork", "apple-music", "metadata"],
      "official": true,
      "min_app_version": "1.6.2"
    }
  ]
}
